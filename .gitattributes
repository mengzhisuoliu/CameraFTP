# Auto detect text files and perform LF normalization
* text=auto eol=lf
# Ensure all source code files use LF
*.rs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
# Binary files - do not treat as text
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
src-tauri/resources/luts/*.cube filter=lfs diff=lfs merge=lfs -text
