<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- AI Edit progress bar — compact single-line with highlight sweep -->
    <FrameLayout
        android:id="@+id/ai_edit_progress_container"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="92dp"
        android:background="@drawable/progress_bar_bg"
        android:clipToOutline="true"
        android:visibility="gone">

        <!-- Progress fill base color + highlight sweep overlay -->
        <FrameLayout
            android:id="@+id/ai_edit_progress_fill"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:background="@drawable/progress_bar_fill"
            android:clipChildren="true">

            <View
                android:id="@+id/ai_edit_progress_highlight"
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:background="@drawable/progress_bar_highlight"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Bottom edge line track -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_gravity="bottom"
            android:background="#0DFFFFFF" />

        <!-- Bottom edge line progress -->
        <View
            android:id="@+id/ai_edit_progress_edge"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_gravity="bottom|start"
            android:background="@drawable/progress_bar_edge" />

        <!-- Content row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp">

            <TextView
                android:id="@+id/ai_edit_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#60A5FA"
                android:textSize="12sp"
                android:text="AI修图中..."
                android:visibility="gone" />

            <TextView
                android:id="@+id/ai_edit_progress_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp"
                android:layout_marginStart="6dp" />

            <TextView
                android:id="@+id/ai_edit_failure_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F87171"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/ai_edit_cancel_btn"
                android:layout_width="44dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:textColor="#80FFFFFF"
                android:textSize="11sp"
                android:text="取消"
                android:layout_marginStart="4dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Bottom floating bar -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bottom_bar_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp">

        <!-- Left: filename + EXIF info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:minWidth="0dp">

            <TextView
                android:id="@+id/filename"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E5E7EB"
                android:textSize="14sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="middle" />

            <TextView
                android:id="@+id/exif_params"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:singleLine="true"
                android:layout_marginTop="3dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/exif_datetime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:singleLine="true"
                android:layout_marginTop="2dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Right: action buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_ai_edit"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_ai_edit"
                android:background="@drawable/btn_circle_bg"
                android:contentDescription="AI修图"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btn_rotate"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_rotate"
                android:background="@drawable/btn_circle_bg"
                android:contentDescription="切换横竖屏"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <ImageButton
                android:id="@+id/btn_delete"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_delete"
                android:background="@drawable/btn_circle_bg"
                android:contentDescription="删除图片"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="0dp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
