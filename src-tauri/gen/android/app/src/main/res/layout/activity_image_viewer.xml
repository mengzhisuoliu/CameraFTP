<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Task progress panel — bottom-left floating -->
    <LinearLayout
        android:id="@+id/task_progress_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="92dp"
        android:orientation="vertical"
        android:background="@drawable/task_panel_bg"
        android:visibility="gone"
        android:minWidth="180dp">

        <!-- Header -->
        <TextView
            android:id="@+id/task_panel_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:text="后台任务" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#1AFFFFFF" />

        <!-- AI Edit task row -->
        <LinearLayout
            android:id="@+id/task_row_ai_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#60A5FA"
                android:textSize="12sp"
                android:text="AI修图：" />

            <TextView
                android:id="@+id/task_ai_edit_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/task_ai_edit_failed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F87171"
                android:textSize="12sp"
                android:layout_marginStart="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/task_ai_edit_cancel"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:gravity="center"
                android:textColor="#66FFFFFF"
                android:textSize="14sp"
                android:text="×"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Color Grading task row -->
        <LinearLayout
            android:id="@+id/task_row_color_grading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#A78BFA"
                android:textSize="12sp"
                android:text="调色：" />

            <TextView
                android:id="@+id/task_cg_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/task_cg_failed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F87171"
                android:textSize="12sp"
                android:layout_marginStart="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/task_cg_cancel"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:gravity="center"
                android:textColor="#66FFFFFF"
                android:textSize="14sp"
                android:text="×"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#1AFFFFFF" />

        <!-- Footer -->
        <TextView
            android:id="@+id/task_panel_footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:textColor="#66FFFFFF"
            android:textSize="11sp"
            android:text="全部取消" />

    </LinearLayout>

    <!-- Bottom floating bar -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bottom_bar_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp">

        <!-- Left: filename + EXIF info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:minWidth="0dp">

            <TextView
                android:id="@+id/filename"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E5E7EB"
                android:textSize="14sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="middle" />

            <TextView
                android:id="@+id/exif_params"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:singleLine="true"
                android:layout_marginTop="3dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/exif_datetime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:singleLine="true"
                android:layout_marginTop="2dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Right: action buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_menu_overflow"
                android:background="@drawable/btn_circle_bg"
                android:contentDescription="菜单"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <ImageButton
                android:id="@+id/btn_rotate"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_rotate"
                android:background="@drawable/btn_circle_bg"
                android:contentDescription="切换横竖屏"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <ImageButton
                android:id="@+id/btn_delete"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_delete"
                android:background="@drawable/btn_circle_bg"
                android:contentDescription="删除图片"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="0dp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
